# ─── App ───────────────────────────────────────────
APP_URL=https://whiteboard.example.com
NODE_ENV=production

# ─── MongoDB ───────────────────────────────────────
# With docker-compose.prod.example.yml, the backend MONGODB_URI is derived from these values.
# If you set MONGODB_URI directly, it takes priority (e.g. for managed MongoDB).
MONGO_ROOT_USERNAME=fosscalidraw
MONGO_ROOT_PASSWORD=replace-with-a-long-random-password
# MONGODB_URI=

# ─── Auth.js ───────────────────────────────────────
# Public auth base URL. This should match APP_URL in production.
AUTH_URL=https://whiteboard.example.com

# Generate at least 32 random characters, for example: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Configure at least one complete provider.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_NAME=Management App
AUTH_OIDC_SCOPE=openid email profile

# Must stay disabled in production.
AUTH_DEV_OIDC=false
VITE_DEV_OIDC=false

# ─── App limits ────────────────────────────────────
JSON_BODY_LIMIT=10mb
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240
