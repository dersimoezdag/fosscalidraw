# ─── App ───────────────────────────────────────────
APP_URL=https://whiteboard.example.com
NODE_ENV=production

# ─── MongoDB ───────────────────────────────────────
# Use a strong password. For managed MongoDB, set only MONGODB_URI and adapt docker-compose accordingly.
MONGO_ROOT_USERNAME=fosscalidraw
MONGO_ROOT_PASSWORD=replace-with-a-long-random-password
MONGODB_URI=mongodb://fosscalidraw:replace-with-a-long-random-password@mongo:27017/fosscalidraw?authSource=admin

# ─── Auth.js ───────────────────────────────────────
# Generate at least 32 random characters, for example: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Configure at least one complete provider.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_NAME=Management App

# Must stay disabled in production.
AUTH_DEV_OIDC=false
VITE_DEV_OIDC=false

# ─── Backend ───────────────────────────────────────
BACKEND_PORT=3001
JSON_BODY_LIMIT=10mb
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240
