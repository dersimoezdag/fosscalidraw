#!/bin/sh
set -eu

if [ -z "${BACKEND_URI:-}" ]; then
  echo "[startup] Frontend startup failed. BACKEND_URI is not set."
  echo "[startup] Set BACKEND_URI to the backend origin reachable from this container."
  echo "[startup] Examples: http://backend:3001 for Docker Compose, or https://api.example.com for Coolify/external backend."
  return 1
fi

case "$BACKEND_URI" in
  */)
    BACKEND_URI="${BACKEND_URI%/}"
    export BACKEND_URI
    echo "[startup] Normalized BACKEND_URI to ${BACKEND_URI}"
    ;;
esac

echo "[startup] Using backend origin: ${BACKEND_URI}"
