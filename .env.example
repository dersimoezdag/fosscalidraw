# ─── App ───────────────────────────────────────────
APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────
# Option A: Set MONGODB_URI directly (takes priority; managed MongoDB, custom host, etc.)
# Option B: Leave MONGODB_URI empty — docker-compose builds it from the fields below
MONGO_ROOT_USERNAME=fosscalidraw
MONGO_ROOT_PASSWORD=change-me-local-mongo-password
MONGODB_URI=

# ─── Auth.js ───────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-32-char-string

# ── Standalone: Direct OAuth providers ─────────────
# Google (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Federated: External OIDC management app ────────
# Leave empty for standalone mode.
# Set these to delegate auth to your own OIDC provider.
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_NAME=Management App
AUTH_OIDC_TOKEN_AUTH_METHOD=client_secret_post
AUTH_OIDC_WELL_KNOWN=
AUTH_OIDC_ID_TOKEN=true

# Development-only OIDC simulation.
AUTH_DEV_OIDC=true
AUTH_DEV_OIDC_EMAIL=dev@example.local
AUTH_DEV_OIDC_NAME=Dev OIDC User
AUTH_DEV_OIDC_ROLE=editor
VITE_DEV_OIDC=true

# ─── Backend ───────────────────────────────────────
BACKEND_PORT=3000
JSON_BODY_LIMIT=10mb
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=1200

# ─── Frontend (dev mode — Vite dev server on port 5173) ───
# When running frontend via `npm run dev`, set VITE_BACKEND_URL to the backend address.
# With docker-compose dev mode, the backend serves everything on BACKEND_PORT.
VITE_BACKEND_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
