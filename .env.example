# ─── App ───────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/fosscalidraw

# ─── Auth.js ───────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-32-char-string

# ── Standalone: Direct OAuth providers ─────────────
# Google (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Federated: External OIDC management app ────────
# Leave empty for standalone mode.
# Set these to delegate auth to your own OIDC provider.
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_NAME=Management App

# Development-only OIDC simulation.
AUTH_DEV_OIDC=true
AUTH_DEV_OIDC_EMAIL=dev@example.local
AUTH_DEV_OIDC_NAME=Dev OIDC User
AUTH_DEV_OIDC_ROLE=editor
VITE_DEV_OIDC=true

# ─── Backend ───────────────────────────────────────
BACKEND_PORT=3001
JWT_SECRET=change-me-to-another-random-secret

# ─── Frontend ──────────────────────────────────────
VITE_BACKEND_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
